generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  teacher
  student
  admin
}

enum StudentMode {
  school
  direct
}

enum AuthProvider {
  email
  yandex
  vk
  school_code
}

enum AssignmentKind {
  classwork
  homework
  project
}

enum SubmissionStatus {
  not_started
  draft
  submitted
  auto_checked
  pending_teacher_review
  needs_revision
  graded
}

enum CourseModule {
  A
  B
  C
  D
}

model User {
  id             String      @id @default(cuid())
  email          String?     @unique
  nickname       String      @unique
  passwordHash   String?
  provider       AuthProvider @default(email)
  providerUserId String?
  role           UserRole    @default(student)
  studentMode    StudentMode @default(direct)
  avatarUrl      String?
  lastActiveAt   DateTime?
  emailVerifiedAt DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  schoolsOwned      School[]
  classroomsTaught  Classroom[]
  enrollments       Enrollment[]
  projects          Project[]
  assignmentsOwned  Assignment[] @relation("AssignmentOwner")
  submissions       Submission[]
  learningProgress  LearningProgress[]
  modelRunStats     ModelRunStat[]
  analyticsEvents   AnalyticsEvent[]
  spriteSelection   UserSpriteSelection?
  refreshTokens     RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  projectSharesCreated ProjectShare[]
  scheduleSlotAttendances ScheduleSlotAttendance[]
  lessonPlayerProgress LessonPlayerProgress[]
}

/// Прогресс интерактивного плеера урока (direct: scopeKey = "direct", школа: scopeKey = id задания)
model LessonPlayerProgress {
  id               String   @id @default(cuid())
  userId           String
  lessonTemplateId String
  scopeKey         String   @default("direct")
  state            Json     @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonTemplate LessonTemplate @relation(fields: [lessonTemplateId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonTemplateId, scopeKey])
  @@index([lessonTemplateId, scopeKey])
}

// Одноразовый код подтверждения email перед регистрацией
model RegistrationOtp {
  id        String   @id @default(cuid())
  email     String   @unique
  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
}

// Токен сброса пароля (в БД только хэш)
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model School {
  id          String   @id @default(cuid())
  name        String
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner      User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  classrooms Classroom[]
}

model Classroom {
  id           String       @id @default(cuid())
  schoolId     String
  teacherId    String
  title        String
  code         String       @unique
  courseModule CourseModule @default(A)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  school         School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacher        User                @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  enrollments    Enrollment[]
  inviteCodes    InviteCode[]
  assignments    Assignment[]
  scheduleSlots  ClassScheduleSlot[]
}

model Enrollment {
  id                 String    @id @default(cuid())
  classroomId        String
  studentId          String
  joinedAt           DateTime  @default(now())
  // Учитель отметил просмотр нового ученика (вкладка «Классы»)
  teacherSeenJoinAt  DateTime?

  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  student   User      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classroomId, studentId])
}

model InviteCode {
  id          String   @id @default(cuid())
  classroomId String
  code        String   @unique
  active      Boolean  @default(true)
  expiresAt   DateTime?
  createdAt   DateTime @default(now())

  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
}

model Project {
  id          String   @id
  userId      String
  title       String
  isCloud                 Boolean  @default(true)
  /// Проект открыт из каталога уроков (самостоятельное обучение)
  lessonTemplateId        String?
  /// Урок каталога отмечен пройденным — на главной предлагается следующий
  catalogLessonComplete   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonTemplate LessonTemplate? @relation(fields: [lessonTemplateId], references: [id], onDelete: SetNull)
  snapshot       ProjectSnapshot?
  datasets       DatasetMeta[]
  submissions    Submission[]
  sharesSource   ProjectShare[] @relation("ShareSourceProject")
}

model ProjectSnapshot {
  id         String   @id @default(cuid())
  projectId  String   @unique
  payload    Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model DatasetMeta {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  kind        String
  sampleCount Int      @default(0)
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model LearningProgress {
  id          String   @id @default(cuid())
  userId      String
  moduleKey   String
  topicKey    String
  progress    Float    @default(0)
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleKey, topicKey])
}

model LessonTemplate {
  id             String   @id @default(cuid())
  title          String
  description    String?
  moduleKey      String
  sortOrder      Int      @default(0)
  starterPayload Json
  lessonContent  Json?
  published      Boolean  @default(true)
  teacherGuideMd String?  @db.Text
  studentSummary String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  assignments     Assignment[]
  scheduleSlots   ClassScheduleSlot[]
  catalogProjects Project[]
  lessonPlayerProgress LessonPlayerProgress[]
}

model ClassScheduleSlot {
  id               String   @id @default(cuid())
  classroomId      String
  lessonTemplateId String?
  startsAt         DateTime
  endsAt           DateTime?
  durationMinutes  Int      @default(90)
  notes            String?
  weeklySeriesId   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  classroom      Classroom       @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  lessonTemplate LessonTemplate? @relation(fields: [lessonTemplateId], references: [id], onDelete: SetNull)
  attendances      ScheduleSlotAttendance[]
  slotAssignments  Assignment[]    @relation("AssignmentScheduleSlot")

  @@index([classroomId, startsAt])
  @@index([weeklySeriesId])
}

// Необязательная отметка ученика: планирует прийти на занятие (для учителя не редактируется здесь)
model ScheduleSlotAttendance {
  id            String   @id @default(cuid())
  slotId        String
  studentId     String
  plansToAttend Boolean?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  slot    ClassScheduleSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  student User              @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([slotId, studentId])
  @@index([studentId])
}

model Assignment {
  id               String         @id @default(cuid())
  classroomId      String
  ownerId          String
  title            String
  description      String?
  kind             AssignmentKind @default(homework)
  maxScore         Int            @default(10)
  published        Boolean        @default(true)
  templateSnapshot Json?
  lessonTemplateId String?
  scheduleSlotId   String?
  dueAt            DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  classroom       Classroom        @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  owner           User             @relation("AssignmentOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  lessonTemplate  LessonTemplate?  @relation(fields: [lessonTemplateId], references: [id], onDelete: SetNull)
  scheduleSlot    ClassScheduleSlot? @relation("AssignmentScheduleSlot", fields: [scheduleSlotId], references: [id], onDelete: Cascade)
  submissions     Submission[]

  @@index([scheduleSlotId])
}

model Submission {
  id           String           @id @default(cuid())
  assignmentId String
  studentId    String
  projectId    String?
  score        Int?
  autoScore    Int?
  manualScore  Int?
  scoreBreakdown Json?
  status       SubmissionStatus @default(not_started)
  teacherNote  String?
  revisionNote String?
  submittedAt  DateTime?
  gradedAt     DateTime?
  teacherSeenAt DateTime?
  gradedSeenAt  DateTime?
  homeworkDueReminderSentAt DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student    User       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  project    Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@unique([assignmentId, studentId])
}

model ProjectShare {
  id              String    @id @default(cuid())
  token           String    @unique
  sourceProjectId String
  createdById     String
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())

  sourceProject Project @relation("ShareSourceProject", fields: [sourceProjectId], references: [id], onDelete: Cascade)
  createdBy     User    @relation(fields: [createdById], references: [id], onDelete: Cascade)
}

model ModelRunStat {
  id              String   @id @default(cuid())
  userId          String
  projectId       String?
  modelType       String
  runs            Int      @default(0)
  trainCount      Int      @default(0)
  predictCount    Int      @default(0)
  avgDurationMs   Float?
  lastResultLabel String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String
  name      String
  payload   Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AvatarCharacter {
  id          String   @id @default(cuid())
  key         String   @unique
  title       String
  description String?
  previewUrl  String?
  createdAt   DateTime @default(now())

  selections UserSpriteSelection[]
}

model SpritePack {
  id          String   @id @default(cuid())
  key         String   @unique
  title       String
  description String?
  previewUrl  String?
  createdAt   DateTime @default(now())

  selections UserSpriteSelection[]
}

model UserSpriteSelection {
  id          String   @id @default(cuid())
  userId      String   @unique
  characterId String?
  spritePackId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  character AvatarCharacter? @relation(fields: [characterId], references: [id], onDelete: SetNull)
  spritePack SpritePack?     @relation(fields: [spritePackId], references: [id], onDelete: SetNull)
}
